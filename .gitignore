# ===============================
# Poker Analyzer — Optimized .gitignore
# ===============================

# --- System / Editor ---
# Global macOS metadata noise (including content/* trees)
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.iml

# --- Flutter / Dart ---
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
**/doc/api/
**/ios/Flutter/.last_build_id

# --- Generated / Cache / Logs ---
*.log
*.tmp
*.pid
*.dill
*.dill.track.dill
*.lock
*.bak
*.old
*.orig
coverage/
.cache/
**/.history/
**/.buildlog/

# --- Session/CLI logs and snapshots ---
codex_*.txt
flutter_*.txt
dart_analyze*.txt
dartanalyze*.log

# --- Duplicate snapshots ---
* copy.md

# --- Local audit / session exports ---
pa_audit_*/
export/sessions/
telemetry/*.log

# --- macOS / Windows artifacts ---
*.xcworkspace/
*.xcodeproj/
DerivedData/
*.exe
*.dll
*.pdb
*.app/
*.app.dSYM/
*.zip
*.tar
*.tar.gz

# Keep iOS project files trackable when ios target is enabled.
!ios/Runner.xcodeproj/
!ios/Runner.xcodeproj/**
!ios/Runner.xcworkspace/
!ios/Runner.xcworkspace/**

# --- Flutter build outputs ---
/android/app/debug
/android/app/profile
/android/app/release
/macos/Pods/
/windows/flutter/ephemeral/
/windows/flutter/ephemeral/.plugin_symlinks/

# --- Python virtual envs ---
.venv/
venv/
env/
__pycache__/
*.pyc

# --- Reports that can be regenerated ---
build/test_cache/
test/.DS_Store
test_v2/.DS_Store
release/_quarantine/
release/_archives/
tools/_cache/
tools/_tmp/
adaptive_learning_summary.json
adaptive_loop_v2_report.json
adaptive_loop_v3_report.json

# --- Allow critical artifacts ---
!release/_reports/
!release/_exports/
!tools/
tools/_reports/
!lib/
!content/
!assets/
!test/
!pubspec.yaml
!analysis_options.yaml
!README.md

# Autogenerated local reports (do not commit)
adaptive_learning_summary.json
adaptive_loop_v2_report.json
adaptive_loop_v3_report.json
tools/_reports/
.git-rewrite/
# Modern table screenshots
out/modern_table_*.png
# out/ is generated/local by default (exceptions explicitly whitelisted)
out/*
!out/README.md
!out/modern_table_screenshots_v1.zip

l10n_untranslated_report.txt
assets/audit_hub_v1/history_index.json
assets/audit_hub_v1/latest_run.json
assets/audit_hub_v1/world_screenshot_evidence_v1/world3/
assets/audit_hub_v1/world_screenshot_evidence_v1/world4/
